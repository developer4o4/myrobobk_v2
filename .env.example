# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=0
ALLOWED_HOSTS=api.myrobo.uz,myrobo.uz

# Database
POSTGRES_DB=myapp
POSTGRES_USER=myapp
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Telegram Bot
BOT_OTP_SECRET=change-this-secret
BOT_TOKEN=your-telegram-bot-token-here

# API
API_URL=https://api.myrobo.uz/user/auth/bot/create-otp/

# Docker Judge
DOCKER_HOST=tcp://dind:2375
JUDGE_IMAGE=judge-sandbox:latest
JUDGE_RUNS_VOLUME=judge_runs

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://myrobo.uz
CSRF_TRUSTED_ORIGINS=https://api.myrobo.uz,https://myrobo.uz
